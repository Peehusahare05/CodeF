# For deployed frontend, set your API base URL.
VITE_API_URL=https://your-api-domain.com

# Backward-compatible variable (optional).
VITE_API_BASE_URL=https://your-api-domain.com

# Optional dev proxy target for npm run dev.
VITE_DEV_API_PROXY_TARGET=http://localhost:5001

# Production frontend domain used for canonical/OG/schema URLs.
VITE_SITE_URL=https://ecotrack.app
